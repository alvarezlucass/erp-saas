// Unifai - Schema de base de datos
// Multi-tenant SaaS Architecture

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── SaaS / MULTI-TENANT ─────────────────────────────────────────────────────

model Empresa {
  id              String   @id @default(cuid())
  nombre          String   @unique
  cuit            String   @unique
  logoUrl         String?
  plan            String   @default("BASIC") // BASIC, PRO, ENTERPRISE
  usuariosExtra   Int      @default(0)
  modulos         String[] @default(["ADMIN", "INVENTARIO", "COMERCIAL"])
  activa          Boolean  @default(true)
  creadoEn        DateTime @default(now())
  actualizadoEn   DateTime @updatedAt
  vencimiento     DateTime?
  
  // Localización
  pais            String   @default("AR")
  moneda          String   @default("ARS")

  membresias      Membresia[]
  insumos         Insumo[]
  notificaciones  Notificacion[]
  productos       Producto[]
  presupuestos    Presupuesto[]
  pedidos         Pedido[]
  clientes        Cliente[]
  proveedores     Proveedor[]
  instituciones   Institucion[]
  cuentas         Cuenta[]
  configuraciones Configuracion[]
  bordados        Bordado[]
  categorias      CategoriaProducto[]
  curvas          CurvaTalle[]
  puntosMedicion  PuntoMedicion[]
  importaciones   ImportacionStaging[]
  auditoriasCancelacion AuditoriaCancelacion[]
  subCategorias   SubCategoriaProducto[]
  ordenesCompra   OrdenCompra[]
  recepciones     RecepcionMercaderia[]
  cambiosPrecio   CambioPrecioProgramado[]
  comprobantes    Comprobante[]
  movimientosCC   MovimientoCuentaCorriente[]

  @@map("empresas")
}

model AuditoriaCancelacion {
  id               String   @id @default(cuid())
  empresaId        String
  usuarioId        String
  clienteNombre    String?
  monto            Float
  unidades         Int
  motivo           String
  itemsJson        Json?    // Snapshot de lo que se iba a vender
  fechaInicio      DateTime
  fechaCancelacion DateTime @default(now())

  empresa Empresa @relation(fields: [empresaId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@map("auditorias_cancelacion")
}

// ─── IMPORTACIÓN CON STAGING ─────────────────────────────────────────────────

model ImportacionStaging {
  id          String    @id @default(cuid())
  empresaId   String
  tipo        String    // INSUMOS, PRODUCTOS, PRECIOS
  archivoUrl  String    // Ruta del archivo guardado
  nombre      String    // Nombre original del archivo
  estado      String    @default("PENDIENTE") // PENDIENTE, REVISADO, EJECUTADO, ERROR
  jsonData    Json?     // JSON procesado y revisado listo para ejecutar
  notas       String?   // Observaciones del revisor (Super Admin)
  creadoEn    DateTime  @default(now())
  ejecutadoEn DateTime?

  empresa  Empresa @relation(fields: [empresaId], references: [id])

  @@map("importaciones_staging")
}

// ─── USUARIOS ────────────────────────────────────────────────────────────────

model Usuario {
  id           String   @id @default(cuid())
  nombre       String
  email        String?  @unique // Identidad Global del usuario (opcional)
  passwordHash String
  activo       Boolean  @default(true)
  debeCambiarPassword Boolean @default(true)
  creadoEn     DateTime @default(now())
  
  identificadorNacional String? @unique // DNI / CUIT / RUT (Oculto inicial, único)

  membresias      Membresia[]
  auditoriasCancelacion AuditoriaCancelacion[]
  movimientos     Movimiento[]
  MovimientoStock MovimientoStock[]
  notificaciones  Notificacion[]
  cambiosPrecio   CambioPrecioProgramado[]
  etapasPedido    EtapaPedido[]

  @@map("usuarios")
}

// Tabla Puente para Multi-Sucursal
model Membresia {
  id           String   @id @default(cuid())
  usuarioId    String
  empresaId    String
  
  rol          String   @default("OPERADOR") // SUPER_ADMIN, CLIENT_ADMIN, OPERADOR, LECTOR
  tarifaVenta  String   @default("PRECIO_FINAL")
  permisos     String[] @default(["VENTAS"])
  activo       Boolean  @default(true)
  preferencias Json?    @default("{}")
  creadoEn     DateTime @default(now())

  usuario      Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  empresa      Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  // Historial de cierres de venta (anteriormente directos en Usuario)
  presupuestosFinalizados Presupuesto[] @relation("UsuarioFinaliza")
  presupuestos            Presupuesto[]

  @@unique([usuarioId, empresaId])
  @@map("membresias")
}

// ─── INSUMOS Y COSTOS ────────────────────────────────────────────────────────

model Insumo {
  id            String  @id @default(cuid())
  empresaId     String
  codigoInterno String? // SKU o Código Industrial
  tipo          String // TELA, COSTURA, BORDADO, ACCESORIO, CIERRE, etc.
  categoria     String // Piquet, Deportivo, CHOMBA, etc.
  nombre        String
  descripcion   String? // Notas técnicas adicionales
  unidad        String? // metro, unidad, kg, cono

  // Datos Técnicos Textiles
  composicion String? // ej: "65% Algodón / 35% Poliéster"
  gramaje     Int? // GSM (g/m2)
  ancho       Float? // Ancho de pieza en metros (ej: 1.60)
  color       String? // Nombre o Código Pantone

  // Multimedia Industrial
  fotoUrl         String? // Imagen del material (muestrario)
  fichaTecnicaUrl String? // Imagen de etiqueta o ficha composición

  stockActual   Float    @default(0)
  stockMinimo   Float?   @default(0)
  codigoBarra   String?
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  talle            String? // Talle del producto (42, XL, etc.)
  especificaciones String? // Fajas, seguridad, etc.

  empresa     Empresa           @relation(fields: [empresaId], references: [id])
  proveedorId String?
  proveedores InsumoProveedor[]
  precios     PrecioInsumo[]
  usos        InsumoProducto[]
  movimientos MovimientoStock[]
  lineasOC    LineaOrdenCompra[]
  lineasRecepcion LineaRecepcion[]

  @@unique([tipo, nombre, talle, empresaId])
  @@map("insumos")
}

model MovimientoStock {
  id              String   @id @default(cuid())
  insumoId        String?
  productoTalleId String? // Vínculo con producto terminado
  tipo            String // INGRESO, EGRESO, CONSUMO_PRODUCCION, AJUSTE, VENTA, TALLER
  cantidad        Float
  motivo          String?
  pedidoId        String? // Relación opcional con un pedido
  usuarioId       String? // Auditoría: Quién lo hizo
  proveedorId     String? // Para vincular el ingreso a un proveedor específico
  costoUnitario   Float?   // Costo capturado en el momento de la recepción
  creadoEn        DateTime @default(now())

  insumo        Insumo?        @relation(fields: [insumoId], references: [id])
  productoTalle ProductoTalle? @relation(fields: [productoTalleId], references: [id])
  pedido        Pedido?        @relation(fields: [pedidoId], references: [id])
  usuario       Usuario?       @relation(fields: [usuarioId], references: [id])
  proveedor     Proveedor?     @relation(fields: [proveedorId], references: [id])

  @@map("movimientos_stock")
}

model Proveedor {
  id                String  @id @default(cuid())
  empresaId         String
  nombre            String // Nombre fantasía
  razonSocial       String?
  cuit              String?
  // Domicilio Legal (Facturación)
  dirLegalCalle     String?
  dirLegalNro       String?
  dirLegalPiso      String?
  dirLegalCiudad    String?
  dirLegalProvincia String?
  dirLegalCP        String?

  // Domicilio Real (Operativo / Retiro)
  dirRealCalle     String?
  dirRealNro       String?
  dirRealPiso      String?
  dirRealCiudad    String?
  dirRealProvincia String?
  dirRealCP        String?

  // Condiciones Comerciales
  formaPago     String? // "Transferencia", "Efectivo", "Cheque"
  diasPago      Int?    @default(0) // 0, 30, 60 días
  tiempoEntrega String? // "7 días hábiles"
  medioPedido   String? // "WhatsApp", "Email", "Portal"

  telefono       String?
  email          String?
  contactoNombre String?
  rubro          String? // "Telas", "Talleres", "Insumos", "Mercadería"
  notas          String?
  activo         Boolean  @default(true)
  creadoEn       DateTime @default(now())
  actualizadoEn  DateTime @updatedAt

  empresa   Empresa             @relation(fields: [empresaId], references: [id])
  insumos   InsumoProveedor[]
  productos ProductoProveedor[]
  movimientosStock MovimientoStock[]
  ordenesCompra    OrdenCompra[]
  recepciones      RecepcionMercaderia[]
  comprobantes     Comprobante[]
  movimientosCC    MovimientoCuentaCorriente[]

  @@unique([nombre, empresaId])
  @@map("proveedores")
}

model PrecioInsumo {
  id         String   @id @default(cuid())
  insumoId   String
  costo      Float
  fechaDesde DateTime @default(now())
  motivo     String? // "Aumento proveedor NORTEXTIL +5%", etc.
  creadoEn   DateTime @default(now())

  insumo Insumo @relation(fields: [insumoId], references: [id])

  @@map("precios_insumos")
}

model InsumoProveedor {
  id               String   @id @default(cuid())
  insumoId         String
  proveedorId      String
  codigoReferencia String? // SKU del proveedor
  costo            Float? // Precio especifico de este proveedor
  tiempoEntrega    String? // Lead time (ej: "7 días")
  leadTimeDays     Int? // Días corridos para cálculo automático
  esPrincipal      Boolean  @default(false)
  creadoEn         DateTime @default(now())

  insumo    Insumo    @relation(fields: [insumoId], references: [id], onDelete: Cascade)
  proveedor Proveedor @relation(fields: [proveedorId], references: [id], onDelete: Cascade)

  @@unique([insumoId, proveedorId])
  @@map("insumo_proveedores")
}

model ProductoProveedor {
  id               String   @id @default(cuid())
  productoId       String
  proveedorId      String
  codigoReferencia String? // SKU del proveedor
  costo            Float? // Costo especifico de este proveedor
  tiempoEntrega    String? // Lead time (ej: "7 días")
  esPrincipal      Boolean  @default(false)
  creadoEn         DateTime @default(now())

  producto  Producto  @relation(fields: [productoId], references: [id], onDelete: Cascade)
  proveedor Proveedor @relation(fields: [proveedorId], references: [id], onDelete: Cascade)

  @@unique([productoId, proveedorId])
  @@map("producto_proveedores")
}

// ─── PRODUCTOS ───────────────────────────────────────────────────────────────

model Producto {
  id        String   @id @default(cuid())
  empresaId String
  nombre    String // "Chomba Manga Corta", "Campera Deportiva"
  activo    Boolean  @default(true)
  creadoEn  DateTime @default(now())

  tipo String @default("FABRICADO") // FABRICADO, COMPRADO, SEMI_TERMINADO
  tipoVenta String @default("UNIDAD") // UNIDAD, FRACCIONADO
  temporada String? @default("TODO EL AÑO") // VERANO, INVIERNO, TODO EL AÑO
  costoCompra Float?   // Costo de compra base (para productos COMPRADO)

  codigoBarra String? // Para pistolear en Punto de Venta

  categoriaId String?
  categoria   CategoriaProducto? @relation(fields: [categoriaId], references: [id])

  subCategoriaId String?
  subCategoria   SubCategoriaProducto? @relation(fields: [subCategoriaId], references: [id])

  institucionId String?
  institucion   Institucion? @relation("ProductosInstitucion", fields: [institucionId], references: [id])

  empresa     Empresa             @relation(fields: [empresaId], references: [id])
  proveedores ProductoProveedor[]
  insumos     InsumoProducto[]
  talles   ProductoTalle[]
  medidas  MedidaTalle[]
  imagenes ImagenProducto[]
  bordados ProductoBordado[]
  lineasOC LineaOrdenCompra[]

  actualizadoEn DateTime @updatedAt
  metadata      Json?    // Matriz de consumo: { consumos: { [talle]: { [insumoId]: q } }, avgSelection: string[] }

  // Precios Sugeridos por Segmento
  precioFinal      Float?
  precioRevendedor Float?
  precioEmpresa    Float?
  precioRevendido  Float?
  margenObjetivo   Float?   // Margen porcentual deseado (ej: 0.35)

  lineasPres LineaPresupuesto[]

  @@unique([nombre, empresaId])
  @@map("productos")
}

model ProductoBordado {
  id         String   @id @default(cuid())
  productoId String
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  bordadoId  String
  bordado    Bordado  @relation(fields: [bordadoId], references: [id], onDelete: Cascade)
  posicion   String? // Ej: "Frente Izquierdo", "Espalda Alta"

  @@map("producto_bordados")
}

model Bordado {
  id              String  @id @default(cuid())
  empresaId       String
  nombre          String
  descripcion     String?
  puntadas        Int     @default(0) // Cantidad total de puntadas
  precioPorMillar Float   @default(0) // Tasa por cada 1000 puntadas
  costoPonchado   Float   @default(0) // Costo fijo inicial de matriz
  marginTerceros  Float   @default(30) // Margen extra para servicios externos (%)

  // Precios Sugeridos por Segmento
  precioFinal      Float?
  precioRevendedor Float?
  precioEmpresa    Float?
  precioRevendido  Float?

  fotoUrl          String? // Foto del bordado real
  archivoMatrizUrl String? // Link al archivo .DST, .PES, etc.

  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  empresa   Empresa           @relation(fields: [empresaId], references: [id])
  productos ProductoBordado[]

  @@unique([nombre, empresaId])
  @@map("bordados")
}

model CategoriaProducto {
  id          String  @id @default(cuid())
  empresaId   String
  nombre      String // "Chomba MC", "Pantalón Verano"
  descripcion String?
  dibujoUrl   String? // Imagen de referencia para medidas
  activo      Boolean @default(true)

  parentId      String?
  parent        CategoriaProducto?  @relation("SubCategorias", fields: [parentId], references: [id])
  subCategorias CategoriaProducto[] @relation("SubCategorias")

  empresa          Empresa               @relation(fields: [empresaId], references: [id])
  productos        Producto[]
  puntosReferencia PuntoMedicion[]
  medidasBase      MedidaBaseCategoria[]
  subCategoriasSub SubCategoriaProducto[]

  @@unique([nombre, empresaId])
  @@map("categorias_productos")
}

model SubCategoriaProducto {
  id          String  @id @default(cuid())
  empresaId   String
  nombre      String // "Chombas", "Pantalones"
  categoriaId String

  categoria CategoriaProducto @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  empresa   Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  productos Producto[]

  @@unique([nombre, categoriaId, empresaId])
  @@map("sub_categorias_productos")
}

model CurvaTalle {
  id        String      @id @default(cuid())
  empresaId String
  nombre    String // "Adultos S-XL", "Niños 2-16"
  items     TalleItem[]

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@unique([nombre, empresaId])
  @@map("curvas_talles")
}

model TalleItem {
  id      String @id @default(cuid())
  curvaId String
  nombre  String // "S", "M", "4", "6"
  orden   Int    @default(0) // Para ordenar en la tabla

  curva CurvaTalle @relation(fields: [curvaId], references: [id], onDelete: Cascade)

  @@map("talles_items")
}

model PuntoMedicion {
  id          String  @id @default(cuid())
  empresaId   String
  nombre      String // "Sisa", "Largo Total", "Cintura"
  categoriaId String?

  empresa     Empresa               @relation(fields: [empresaId], references: [id])
  categoria   CategoriaProducto?    @relation(fields: [categoriaId], references: [id])
  medidas     MedidaTalle[]
  medidasBase MedidaBaseCategoria[]

  @@map("puntos_medicion")
}

model MedidaBaseCategoria {
  id          String @id @default(cuid())
  categoriaId String
  talle       String // "S", "M", etc.
  puntoId     String
  valorCm     Float

  categoria CategoriaProducto @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  punto     PuntoMedicion     @relation(fields: [puntoId], references: [id], onDelete: Cascade)

  @@unique([categoriaId, talle, puntoId])
  @@map("medidas_base_categorias")
}

model MedidaTalle {
  id         String @id @default(cuid())
  productoId String
  talle      String // "S", "M", etc.
  puntoId    String
  valorCm    Float

  producto Producto      @relation(fields: [productoId], references: [id])
  punto    PuntoMedicion @relation(fields: [puntoId], references: [id])

  @@map("medidas_talles")
}

model ImagenProducto {
  id         String @id @default(cuid())
  productoId String
  url        String
  etiqueta   String // "FRENTE", "DORSO", "CUELLO", etc.
  posicion   Int    @default(0)

  producto Producto @relation(fields: [productoId], references: [id])

  @@map("imagenes_productos")
}

// Qué insumos componen un producto y en qué cantidad
model InsumoProducto {
  id              String  @id @default(cuid())
  productoId      String
  insumoId        String
  cantidad        Float // metros de tela, unidades, etc.
  consumoVariable Boolean @default(false)

  producto Producto @relation(fields: [productoId], references: [id])
  insumo   Insumo   @relation(fields: [insumoId], references: [id])

  @@unique([productoId, insumoId])
  @@map("insumos_productos")
}

// Talles disponibles por producto con sus multiplicadores de costo
model ProductoTalle {
  id                 String  @id @default(cuid())
  productoId         String
  talle              String // "2-4", "6-8", "10-12", "14-16", "S", "M", "L", "XL"
  pesoKg             Float?
  metrosTela         Float?
  referenciaMolderia String?

  codigoBarra String? // Código específico por SKU (EAN, QR, etc)
  precioVenta Float?   // Precio específico de este talle (opcional, p/ retail)
  stockActual Float             @default(0) // Stock físico de este talle
  entregado   Boolean           @default(false)
  movimientos MovimientoStock[]
  lineasRecepcion LineaRecepcion[]

  producto Producto @relation(fields: [productoId], references: [id])

  @@unique([productoId, talle])
  @@map("productos_talles")
}

// ─── CLIENTES ────────────────────────────────────────────────────────────────

model Cliente {
  id        String  @id @default(cuid())
  empresaId String
  nombre    String // Nombre o fantasía principal
  apellido  String? // Opcional para Consumidor Final
  telefono  String?
  email     String?
  direccion String?

  razonSocial  String?
  cuit         String?
  condicionIva String  @default("CONSUMIDOR_FINAL") // RESPONSABLE_INSCRIPTO, EXENTO, MONOTRIBUTO, CONSUMIDOR_FINAL
  tipoFactura  String  @default("C") // A, B, C, X

  activo   Boolean  @default(true)
  creadoEn DateTime @default(now())
  
  // Gestión 360
  vencimiento     DateTime?
  ultimoCobro     DateTime?
  configSuscripcion Json?     // Módulos, módulos contratados, descuentos escalonados.
  documentos      Json?     // URLs de archivos técnicos/legales.
  saldo           Float     @default(0)

  empresa      Empresa       @relation(fields: [empresaId], references: [id])
  presupuestos  Presupuesto[]
  comprobantes  Comprobante[]
  movimientosCC MovimientoCuentaCorriente[]

  @@unique([nombre, empresaId])
  @@map("clientes")
}

// ─── INSTITUCIONES Y PRECIOS ─────────────────────────────────────────────────

model Institucion {
  id        String   @id @default(cuid())
  empresaId String
  nombre   String
  tipo     String        @default("COLEGIO")
  logoUrl  String?
  contacto String?
  telefono String?
  activo   Boolean  @default(true)
  creadoEn DateTime @default(now())

  empresa             Empresa       @relation(fields: [empresaId], references: [id])
  listas              ListaPrecio[]
  presupuestos        Presupuesto[]
  productosExclusivos Producto[]    @relation("ProductosInstitucion")

  @@unique([nombre, empresaId])
  @@map("instituciones")
}

model ListaPrecio {
  id            String   @id @default(cuid())
  institucionId String
  nombre        String // "Lista Primaria 2025"
  activa        Boolean  @default(true)
  creadoEn      DateTime @default(now())
  actualizadaEn DateTime @updatedAt

  institucion Institucion @relation(fields: [institucionId], references: [id])
  items       ItemLista[]

  @@map("listas_precios")
}

model ItemLista {
  id             String   @id @default(cuid())
  listaId        String
  productoNombre String // nombre visible en la lista
  talle          String
  precioPublico  Float
  costoBase      Float
  margenBruto    Float // 0.35 = 35%
  margenNeto     Float
  actualizadoEn  DateTime @updatedAt

  lista ListaPrecio @relation(fields: [listaId], references: [id])

  @@map("items_lista")
}

// ─── PRESUPUESTOS Y PEDIDOS ───────────────────────────────────────────────────

model Presupuesto {
  id        String @id @default(cuid())
  empresaId String
  numero    Int    @unique

  clienteId String? // El que abona (Cliente / CRM)
  cliente   Cliente? @relation(fields: [clienteId], references: [id])

  institucionId String? // Catálogo usado (Opcional colegios)
  institucion   Institucion? @relation(fields: [institucionId], references: [id])

  clienteNombre   String? // Snapshots
  clienteContacto String?
  clienteTelefono String?
  modoPago        String  @default("TRANSFERENCIA")
  descuento       Float   @default(0)
  recargo         Float   @default(0)
  senia           Float   @default(0)
  subtotal        Float
  total           Float

  // Novedades: Vigencia, Vencimiento e Impuestos
  tipoVencimiento  String    @default("CORRIDOS") // HABILES, CORRIDOS
  diasVigencia     Int       @default(15)
  fechaVencimiento DateTime?
  subtotalGravado  Float     @default(0)
  impuestosIva     Float     @default(0)

  versionDe        String?   // ID del presupuesto original si es una revisión
  costoTotalSnapshot Float   @default(0) // Suma de costos capturados al momento

  canal         String    @default("GESTION") // OFFICIAL | GESTION
  estado        String    @default("VIGENTE") // VIGENTE, PEDIDO, CERRADO, CANCELADO, MOSTRADOR_BORRADOR
  vigenciaHasta DateTime?
  
  // Auditoría y Control de Cobro Mostrador
  pagado          Boolean @default(false)
  requiereFactura Boolean @default(false)
  entregadoTodo   Boolean @default(false)
  cuotas          Int     @default(1)
  recargoPct      Float   @default(0)

  notas         String?
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
  empresa Empresa            @relation(fields: [empresaId], references: [id])
  membresia Membresia?         @relation(fields: [membresiaId], references: [id])
  membresiaId String?
  membresiaFinaliza Membresia? @relation("UsuarioFinaliza", fields: [membresiaFinalizaId], references: [id])
  membresiaFinalizaId String?
  lineas  LineaPresupuesto[]
  pedido  Pedido?

  @@map("presupuestos")
}

model LineaPresupuesto {
  id              String  @id @default(cuid())
  presupuestoId   String
  tipoItem        String  @default("PRODUCTO") // PRODUCTO | SERVICIO_BORDADO
  productoId      String?
  productoNombre  String // snapshot del nombre al momento
  talle           String? // Opcional para servicios puros
  bordado         String?
  estampado       String?
  cantidad        Int
  precioBordado   Float   @default(0)
  precioEstampado Float   @default(0)
  precioUnitario  Float
  subtotal        Float
  costoUnitarioSnapshot Float @default(0) // Captura del costo al presupuestar
  entregado       Boolean @default(true) // Indica si se retiró en mostrador

  presupuesto Presupuesto @relation(fields: [presupuestoId], references: [id], onDelete: Cascade)
  producto    Producto?   @relation(fields: [productoId], references: [id])

  @@map("lineas_presupuesto")
}

// ─── PEDIDOS Y ÓRDENES DE TRABAJO ─────────────────────────────────────────────

model Pedido {
  id            String    @id @default(cuid())
  empresaId     String
  numero        Int       @unique
  presupuestoId String    @unique
  estado        String    @default("PENDIENTE_INSUMOS") // PENDIENTE_INSUMOS, CORTE, CONFECCION, TERMINADO
  canal         String    @default("GESTION")
  fechaEntrega  DateTime?
  notas         String?
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt

  empresa          Empresa           @relation(fields: [empresaId], references: [id])
  presupuesto      Presupuesto       @relation(fields: [presupuestoId], references: [id])
  ordenes          OrdenTrabajo[]
  etapas           EtapaPedido[]
  movimientosStock MovimientoStock[]
  comprobantes     Comprobante[]

  @@map("pedidos")
}

model OrdenTrabajo {
  id          String   @id @default(cuid())
  pedidoId    String
  tipo        String // CORTE, BORDADO, COSTURA
  descripcion String?
  completada  Boolean  @default(false)
  creadoEn    DateTime @default(now())

  pedido Pedido @relation(fields: [pedidoId], references: [id])

  @@map("ordenes_trabajo")
}

// ─── ADMINISTRACIÓN ────────────────────────────────────────────────────────────

model Cuenta {
  id        String  @id @default(cuid())
  empresaId String
  nombre    String // "Caja ahorro", "Cuenta corriente", "Efectivo"
  tipo      String
  activa    Boolean @default(true)

  empresa      Empresa      @relation(fields: [empresaId], references: [id])
  movimientos Movimiento[]

  @@unique([nombre, empresaId])
  @@map("cuentas")
}

model Movimiento {
  id        String   @id @default(cuid())
  cuentaId  String
  tipo      String
  concepto  String
  importe   Float // positivo = ingreso, negativo = egreso
  fecha     DateTime @default(now())
  usuarioId String?
  creadoEn  DateTime @default(now())

  cuenta  Cuenta   @relation(fields: [cuentaId], references: [id])
  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@map("movimientos")
}

// ─── CONFIGURACIÓN ─────────────────────────────────────────────────────────────

model Configuracion {
  id        String @id @default(cuid())
  empresaId String
  clave     String
  valor     String

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@unique([clave, empresaId])
  @@map("configuracion")
}
// ─── AUDITORÍA Y NOVEDADES ───────────────────────────────────────────────────

model Notificacion {
  id        String   @id @default(cuid())
  empresaId String
  titulo    String
  mensaje   String
  tipo      String   @default("INFO") // INFO, SUCCESS, WARNING, DANGER
  leida     Boolean  @default(false)
  
  // Metadatos para filtrar o navegar al evento
  usuarioId String?
  metadata  Json?    // { categoriaId: '...', porcentaje: 10 }
  
  creadoEn  DateTime @default(now())

  empresa   Empresa  @relation(fields: [empresaId], references: [id])
  usuario   Usuario? @relation(fields: [usuarioId], references: [id])

  @@map("notificaciones")
}

// ─── COMPRAS Y RECEPCIONES ───────────────────────────────────────────────────

model OrdenCompra {
  id                  String   @id @default(cuid())
  empresaId           String
  proveedorId         String
  numero              Int      @default(autoincrement())
  estado              String   @default("BORRADOR") // BORRADOR, ENVIADA, RECIBIDA_PARCIAL, RECIBIDA_TOTAL, CANCELADA
  fechaEmision        DateTime @default(now())
  fechaEntregaEstimada DateTime?
  totalEstimado       Float    @default(0)
  notas               String?
  creadoEn            DateTime @default(now())
  actualizadoEn       DateTime @updatedAt

  empresa    Empresa            @relation(fields: [empresaId], references: [id])
  proveedor  Proveedor          @relation(fields: [proveedorId], references: [id])
  items      LineaOrdenCompra[]
  recepciones RecepcionMercaderia[]

  @@unique([numero, empresaId])
  @@map("ordenes_compra")
}

model LineaOrdenCompra {
  id                  String   @id @default(cuid())
  ordenCompraId       String
  insumoId            String?
  productoId          String?
  talle               String?
  cantidadPedida      Float
  cantidadRecibida    Float    @default(0)
  costoUnitarioEstimado Float
  subtotal            Float

  ordenCompra  OrdenCompra      @relation(fields: [ordenCompraId], references: [id], onDelete: Cascade)
  insumo       Insumo?          @relation(fields: [insumoId], references: [id])
  producto     Producto?        @relation(fields: [productoId], references: [id])
  lineasRecepcion LineaRecepcion[]

  @@map("lineas_orden_compra")
}

model RecepcionMercaderia {
  id             String   @id @default(cuid())
  empresaId      String
  proveedorId    String
  ordenCompraId  String?
  nroRemito      String?
  fechaRecepcion DateTime @default(now())
  notas          String?
  creadoEn       DateTime @default(now())

  empresa      Empresa          @relation(fields: [empresaId], references: [id])
  proveedor    Proveedor        @relation(fields: [proveedorId], references: [id])
  ordenCompra  OrdenCompra?     @relation(fields: [ordenCompraId], references: [id])
  items        LineaRecepcion[]

  @@map("recepciones_mercaderia")
}

model LineaRecepcion {
  id                String  @id @default(cuid())
  recepcionId       String
  insumoId          String?
  productoTalleId   String?
  cantidadRecibida  Float
  costoUnitarioReal Float
  lineaOrdenCompraId String?

  recepcion        RecepcionMercaderia @relation(fields: [recepcionId], references: [id], onDelete: Cascade)
  insumo           Insumo?             @relation(fields: [insumoId], references: [id])
  productoTalle    ProductoTalle?      @relation(fields: [productoTalleId], references: [id])
  lineaOrdenCompra LineaOrdenCompra?   @relation(fields: [lineaOrdenCompraId], references: [id])

  @@map("lineas_recepcion")
}

model CambioPrecioProgramado {
  id              String   @id @default(cuid())
  empresaId       String
  tipo            String   // CATEGORIA, PRODUCTO, GLOBAL
  targetId        String?  // ID de categoria o producto
  porcentaje      Float
  fechaEjecucion  DateTime
  ejecutado       Boolean  @default(false)
  usuarioId       String
  creadoEn        DateTime @default(now())

  empresa Empresa @relation(fields: [empresaId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@map("cambios_precio_programados")
}

// ─── FINANZAS Y CUENTAS CORRIENTES ───────────────────────────────────────────

model Comprobante {
  id             String   @id @default(cuid())
  empresaId      String
  tipo           String   // FACTURA_A, FACTURA_B, FACTURA_C, REMITO, RECIBO_X, NOTA_VENTA
  numero         String
  fecha          DateTime @default(now())
  total          Float
  metodoPago     String?  // EFECTIVO, TRANSFERENCIA, TARJETA, CUENTA_CORRIENTE
  esOficial      Boolean  @default(false)
  notas          String?
  creadoEn       DateTime @default(now())

  clienteId      String?
  proveedorId    String?
  pedidoId       String?
  
  empresa        Empresa   @relation(fields: [empresaId], references: [id])
  cliente        Cliente?  @relation(fields: [clienteId], references: [id])
  proveedor      Proveedor? @relation(fields: [proveedorId], references: [id])
  pedido         Pedido?   @relation(fields: [pedidoId], references: [id])
  movimientosCC  MovimientoCuentaCorriente[]

  @@map("comprobantes")
}

model MovimientoCuentaCorriente {
  id             String   @id @default(cuid())
  empresaId      String
  clienteId      String?
  proveedorId    String?
  comprobanteId  String?
  fecha          DateTime @default(now())
  tipo           String   // DEBE (Cargo), HABER (Pago)
  importe        Float
  saldoResultante Float
  descripcion    String?
  creadoEn       DateTime @default(now())

  empresa        Empresa      @relation(fields: [empresaId], references: [id])
  cliente        Cliente?     @relation(fields: [clienteId], references: [id])
  proveedor      Proveedor?    @relation(fields: [proveedorId], references: [id])
  comprobante    Comprobante? @relation(fields: [comprobanteId], references: [id])

  @@map("movimientos_cc")
}

// ─── TRAZABILIDAD DE PRODUCCIÓN ──────────────────────────────────────────────

model EtapaPedido {
  id          String   @id @default(cuid())
  pedidoId    String
  nombreEtapa String   // CORTE, BORDADO, COSTURA, TERMINADO, CONTROL_CALIDAD
  estado      String   @default("PENDIENTE") // PENDIENTE, PROCESO, COMPLETADO, PAUSADO
  usuarioId   String?  // Responsable de la etapa
  fechaInicio DateTime?
  fechaFin    DateTime?
  notas       String?
  creadoEn    DateTime @default(now())

  pedido  Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@map("etapas_pedido")
}
